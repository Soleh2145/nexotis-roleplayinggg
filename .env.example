# =========================================
# KONFIGURASI KEPOLISIAN NEXOTIS (Vercel)
# =========================================
# Cara isi di Vercel: Project Settings > Environment Variables (BUKAN file .env
# yang di-commit). Untuk coba lokal pakai `vercel dev`, buat file ".env.local"
# dengan isi yang sama seperti di bawah — Vercel CLI baca otomatis.

# Generate dengan: openssl rand -base64 32
SESSION_SECRET="ganti-dengan-string-acak"

# --- Discord OAuth2 ("Login with Discord") ---
# https://discord.com/developers/applications > OAuth2 > General
DISCORD_CLIENT_ID="1497623114228695172"
DISCORD_CLIENT_SECRET="vYA8KG2Wu0Ik_CFvF_rWS6bTCp7UJ4Tw"
# Daftarkan persis sama di Discord Developer Portal > OAuth2 > Redirects
# Ganti "nama-project" sesuai domain Vercel kamu setelah deploy pertama kali
DISCORD_REDIRECT_URI="https://nexotis-roleplayinggg.vercel.app/api/auth-callback"

# --- Discord Bot (untuk baca role member) ---
# https://discord.com/developers/applications > Bot > Reset Token
# WAJIB aktifkan "Server Members Intent" di tab Bot
DISCORD_BOT_TOKEN="MTQ5NzYyMzExNDIyODY5NTE3Mg.G88stJ.f-g3GgWDmkpv-9L2crZdaHEI7nG24t3UFy2psI"
DISCORD_GUILD_ID="1463016112773136465"

# --- Pemetaan Role Discord -> Pangkat ---
# Format: "roleId:High Commmand,roleId:HighCommand" (urutan = prioritas)
DISCORD_RANK_MAP="1526826498437288096:High Command,1526826498437288096:High Command,1526826498437288096:Kabid,1526826780525334539:Anggota"

# --- Role yang dianggap HIGH COMMAND (akses Panel Rekap + Reset Semua Duty) ---
DISCORD_HIGH_COMMAND_ROLE_IDS="1526826498437288096,1526826498437288096"

# --- Vercel KV ---
# JANGAN diisi manual. Aktifkan lewat Vercel Dashboard > project kamu > tab
# "Storage" > Create Database > KV. Setelah itu Vercel otomatis menambahkan
# KV_REST_API_URL, KV_REST_API_TOKEN, dll ke Environment Variables sendiri.
